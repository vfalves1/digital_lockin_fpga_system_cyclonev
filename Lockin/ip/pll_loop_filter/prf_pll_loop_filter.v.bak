module prf_pll_loop_filter (
    input wire clk,
    input wire reset,
    
    // Entrada de dados
    input wire signed [29:0] d_erro_bruto,   // Vindo do multiplicador Q
    input wire [31:0] nco_freq_word,        // Palavra de sintonia atual do NCO
    
    // Parâmetros de Controle Dinâmico
    input wire [31:0] kp_gain,              
    input wire [31:0] ki_gain,              
    
    // Coeficientes do Filtro Biquad + Compensador Lead-Lag
    input wire signed [17:0] b0, b1, b2,    
    input wire signed [17:0] a1, a2,        
    
    // Saída de controle
    output reg signed [31:0] nco_freq_mod   
);

    // =========================================================================
    // 1. CAMADA DO FILTRO SINC DINÂMICO (BOXCAR CORRIGIDO)
    // =========================================================================
    reg signed [29:0] sinc_mem [0:127]; 
    reg [6:0] wr_ptr;
    reg [6:0] rd_ptr;
    reg signed [36:0] sinc_acc;
    reg signed [29:0] d_sinc_out;
    
    wire [6:0] K_amostras = (nco_freq_word[31:28] == 4'h0) ? 7'd64 : 
                            (nco_freq_word[31:28] == 4'h1) ? 7'd32 : 7'd16;

    // Ajuste dinâmico do ganho do filtro Sinc baseado no tamanho da janela
    wire [2:0] shift_gain = (nco_freq_word[31:28] == 4'h0) ? 3'd6 :   // 2^6 = 64
                            (nco_freq_word[31:28] == 4'h1) ? 3'd5 :   // 2^5 = 32
                                                             3'd4;    // 2^4 = 16

    // Correção de sincronismo: Atualizar ponteiro de leitura um ciclo antes
    always @(posedge clk) begin
        if (reset) begin
            wr_ptr   <= 7'd0;
            rd_ptr   <= 7'd0;
            sinc_acc <= 37'd0;
            d_sinc_out <= 30'd0;
        end else begin
            rd_ptr <= wr_ptr - K_amostras + 1'b1;
            sinc_mem[wr_ptr] <= d_erro_bruto;
            wr_ptr   <= wr_ptr + 1'b1;
            
            // A matemática usa a leitura síncrona perfeita da RAM
            sinc_acc <= sinc_acc + d_erro_bruto - sinc_mem[rd_ptr];
            
            // Divisão dinâmica baseada na janela ativa para manter o ganho unitário
            d_sinc_out <= (sinc_acc >>> shift_gain); 
        end
    end

    // =========================================================================
    // 2. CAMADA BIQUAD COM ESTRUTURA PIPELINE (GARANTE TIMING DE 50MHz)
    // =========================================================================
    reg signed [29:0] x1, x2; 
    reg signed [31:0] y1, y2; 
    reg signed [29:0] d_biquad_out;

    // Registos de estágio para quebrar o multiplicador combinatório em 2 clocks
    reg signed [47:0] mult_b0, mult_b1, mult_b2;
    reg signed [49:0] mult_a1, mult_a2;
    wire signed [51:0] biquad_sum;

    assign biquad_sum = mult_b0 + mult_b1 + mult_b2 - mult_a1 - mult_a2;

    always @(posedge clk) begin
        if (reset) begin
            x1 <= 30'd0; x2 <= 30'd0;
            y1 <= 32'd0; y2 <= 32'd0;
            d_biquad_out <= 30'd0;
            mult_b0 <= 48'd0; mult_b1 <= 48'd0; mult_b2 <= 48'd0;
            mult_a1 <= 50'd0; mult_a2 <= 50'd0;
        end else begin
            // Estágio 1: Deslocamento do histórico e Multiplicações paralelas (Usa blocos DSP nativos)
            x2 <= x1;
            x1 <= d_sinc_out;
            y2 <= y1;
            
            mult_b0 <= d_sinc_out * b0;
            mult_b1 <= x1 * b1;
            mult_b2 <= x2 * b2;
            mult_a1 <= y1 * a1;
            mult_a2 <= y2 * a2;

            // Estágio 2: Soma e Truncatura controlada
            y1 <= biquad_sum[49:18]; 
            d_biquad_out <= y1[29:0];
        end
    end

    // =========================================================================
    // 3. CAMADA DO FILTRO PI COM ANTI-WINDUP
    // =========================================================================
    reg signed [63:0] integrador;
    reg signed [63:0] prop_term;
    reg signed [63:0] int_term;
    wire signed [63:0] pi_sum;

    assign pi_sum = prop_term + integrador;

    always @(posedge clk) begin
        if (reset) begin
            integrador   <= 64'd0;
            prop_term    <= 64'd0;
            int_term     <= 64'd0;
            nco_freq_mod <= 32'd0;
        end else begin
            // Pipeline nos produtos do PI
            prop_term <= d_biquad_out * $signed({1'b0, kp_gain});
            int_term  <= d_biquad_out * $signed({1'b0, ki_gain});
            
            // Integrador síncrono com proteção simples de estouro
            if ((int_term[63] == 1'b0 && integrador[63] == 1'b0) || (int_term[63] == 1'b1 && integrador[63] == 1'b1)) begin
                integrador <= integrador + int_term;
            end
            
            nco_freq_mod <= pi_sum[63:32];
        end
    end

endmodule